{
  "$schema": "https://schema.tauri.app/config/2/capability.json",
  "identifier": "default",
  "description": "Default capability — grants core IPC and filesystem directory listing for FilePicker",
  "local": true,
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:allow-open",
    {
      "identifier": "fs:allow-read-dir",
      "allow": [{ "path": "**" }]
    }
  ]
}
