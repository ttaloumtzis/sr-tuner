{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SR Tuner",
  "version": "0.1.0",
  "identifier": "io.srtuner.app",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm --prefix frontend run dev",
    "beforeBuildCommand": "npm --prefix frontend run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "SR Tuner",
        "width": 1280,
        "height": 820,
        "minWidth": 1100,
        "minHeight": 700,
        "decorations": false,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/sidecar"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
